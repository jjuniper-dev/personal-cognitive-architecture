{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jjuniper-dev/personal-cognitive-architecture/schemas/canonical-metadata.schema.json",
  "title": "PCA Canonical Metadata Schema",
  "description": "Canonical metadata contract for all knowledge objects within the Personal Cognitive Architecture. Supports both WF10 capture semantics and enterprise governance models.",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "created_at",
    "updated_at",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable globally unique identifier (UUID or workflow-generated)"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title"
    },
    "summary": {
      "type": "string",
      "description": "1-3 sentence summary"
    },
    "type": {
      "type": "string",
      "enum": [
        "note",
        "incident",
        "research",
        "decision",
        "task",
        "reference",
        "conversation",
        "voice",
        "output",
        "capture",
        "meeting",
        "artifact",
        "workflow",
        "architecture",
        "event",
        "relationship",
        "transcript",
        "media",
        "financial_record"
      ],
      "description": "Knowledge object type; WF10 types: note, incident, research, decision, task, reference, conversation, voice, output"
    },
    "status": {
      "type": "string",
      "enum": [
        "raw",
        "validated",
        "reconciled",
        "stale",
        "archived",
        "tension"
      ],
      "description": "WF10 capture status: raw (default), validated, reconciled, stale, archived, or tension (contradiction detected). This is the canonical lifecycle field — WF10 always populates this."
    },
    "state": {
      "type": "string",
      "enum": [
        "captured",
        "inbox",
        "validated",
        "provisional",
        "reconciled",
        "trusted",
        "contested",
        "archived",
        "rejected",
        "deleted",
        "merged",
        "superseded"
      ],
      "description": "Reserved for a future governance layer. WF10 populates `status` only — do not populate `state` until this field is explicitly activated in the governance spec."
    },
    "source": {
      "type": "string",
      "enum": [
        "obsidian",
        "telegram",
        "voice",
        "web",
        "pdf",
        "agent",
        "manual",
        "finance"
      ],
      "description": "WF10 capture source: where the knowledge object originated"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "voice_note",
        "chat",
        "youtube",
        "podcast",
        "web",
        "manual",
        "document",
        "image",
        "email",
        "rss",
        "finance",
        "workflow",
        "system"
      ],
      "description": "Extended source type classification (enterprise model)"
    },
    "source_uri": {
      "type": "string",
      "description": "Original source URL or reference"
    },
    "domain": {
      "type": "string",
      "enum": [
        "personal",
        "work",
        "mixed",
        "system"
      ],
      "description": "Domain classification (enterprise model)"
    },
    "classification": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "description": "WF10 data classification level. This is the canonical routing field — WF10 always populates this. Drives model tier selection: restricted = local only, confidential = Haiku/local only."
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "personal",
        "internal",
        "confidential",
        "restricted"
      ],
      "description": "Reserved for a future personal/work domain split. WF10 populates `classification` only — do not populate `sensitivity` until this field is explicitly activated in the governance spec."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score (0.0-1.0); WF10 default 0.5 for unvalidated"
    },
    "confidence_reasoning": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Reasoning for confidence score"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Free-form tags for categorization"
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": ["string", "object"]
      },
      "description": "Links to related objects; supports both simple string (WF10 style) and complex object formats"
    },
    "conflict_with": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Note IDs this object contradicts (WF10 contradiction detection)"
    },
    "people": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "People mentioned or involved"
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Associated projects"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 creation timestamp (auto-filled by WF10 if not provided)"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 last-modified timestamp (always overwritten by WF10)"
    },
    "last_reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "description": "Trace ID for observability"
    },
    "policy_decision_id": {
      "type": "string"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "not_required",
        "pending",
        "approved",
        "rejected",
        "deferred"
      ]
    },
    "provenance": {
      "type": "object",
      "required": [
        "workflow",
        "timestamp"
      ],
      "properties": {
        "workflow": {
          "type": "string",
          "description": "WF10 or other workflow ID that created/processed this object"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the workflow processed this object"
        },
        "model": {
          "type": ["string", "null"],
          "description": "Model used for classification/enrichment (e.g., llama3.2)"
        },
        "model_version": {
          "type": ["string", "null"],
          "description": "Semantic version or tag of the model"
        },
        "input_hash": {
          "type": "string",
          "description": "SHA256 of raw input for deduplication"
        },
        "captured_by": {
          "type": "string",
          "description": "User or agent that captured this (enterprise model)"
        },
        "original_source": {
          "type": "string",
          "description": "Original source before transformation"
        },
        "source_credibility": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "transformation_history": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Provenance chain; WF10 uses: workflow, timestamp, model, model_version, input_hash"
    },
    "embedding": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "vector_id": {
          "type": "string"
        },
        "vector": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "obsidian_path": {
          "type": "string"
        },
        "neo4j_node_id": {
          "type": "string"
        },
        "qdrant_collection": {
          "type": "string"
        },
        "blob_uri": {
          "type": "string"
        }
      }
    },
    "governance": {
      "type": "object",
      "properties": {
        "requires_human_review": {
          "type": "boolean"
        },
        "approved_for_external_use": {
          "type": "boolean"
        },
        "retention_policy": {
          "type": "string"
        },
        "deletion_approved": {
          "type": "boolean"
        }
      }
    },
    "language": {
      "type": "string",
      "description": "Language code (e.g., en, es, de)"
    }
  },
  "additionalProperties": false
}
