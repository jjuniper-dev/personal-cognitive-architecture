{
  "version": "1.0",
  "description": "Unified routing policy for all ingestion patterns",
  "created": "2026-04-25",
  "last_updated": "2026-04-25",
  "metadata": {
    "philosophy": "One classifier + three routing policies, not three separate systems",
    "source_types": [
      "article",
      "pdf",
      "web",
      "voice",
      "text",
      "email",
      "document",
      "rss",
      "api",
      "structured-input"
    ]
  },
  "routing_rules": [
    {
      "rule_id": "route-001",
      "name": "Structured Knowledge Auto-Route (High Confidence)",
      "description": "Articles/PDFs from reputable sources with high validation confidence",
      "pattern_type": ["article", "pdf", "web", "document"],
      "conditions": {
        "confidence_min": 0.80,
        "source_credibility": ["reputable", "authoritative"],
        "classification": ["unclassified", "public"],
        "reconciliation_status": ["clear", "requires-review"]
      },
      "action": {
        "destination": "{{project}}/Sources",
        "default_folder": "10-Projects/External-Sources",
        "requires_review": false,
        "state": "trusted",
        "tags": ["source", "trusted", "{{project}}", "{{domain}}"],
        "additional_processing": ["add_to_vector_db", "create_relationships"]
      },
      "priority": 1
    },
    {
      "rule_id": "route-002",
      "name": "Structured Knowledge Provisional (Moderate Confidence)",
      "description": "Sources with moderate confidence or mixed credibility",
      "pattern_type": ["article", "pdf", "web", "document"],
      "conditions": {
        "confidence_min": 0.65,
        "confidence_max": 0.79,
        "source_credibility": ["moderate", "reputable"],
        "reconciliation_status": ["clear", "requires-review"]
      },
      "action": {
        "destination": "00-Inbox",
        "requires_review": true,
        "state": "provisional",
        "tags": ["source", "provisional", "review", "{{domain}}"],
        "review_priority": "high",
        "additional_processing": ["add_to_vector_db"]
      },
      "priority": 2
    },
    {
      "rule_id": "route-003",
      "name": "Unstructured Ideas to Inbox (Low Confidence)",
      "description": "Voice notes, quick thoughts, and ideas with low initial confidence",
      "pattern_type": ["voice", "text", "email", "structured-input"],
      "conditions": {
        "confidence_max": 0.75,
        "classification": ["personal", "unclassified"],
        "reconciliation_status": "any"
      },
      "action": {
        "destination": "00-Inbox",
        "requires_review": false,
        "state": "inbox",
        "tags": ["capture", "{{note_type}}", "{{domain}}"],
        "deferred_processing": true,
        "review_optional": true,
        "additional_processing": ["none"]
      },
      "priority": 3,
      "note": "Speed > structure at capture. Promotion is user-driven."
    },
    {
      "rule_id": "route-004",
      "name": "Dynamic Signals High-Confidence Alert",
      "description": "RSS/API feeds with high relevance and urgency",
      "pattern_type": ["rss", "api"],
      "conditions": {
        "overall_score_min": 0.75,
        "urgency_min": 0.60,
        "classification": ["unclassified", "public"]
      },
      "action": {
        "destinations": ["alert_queue", "00-Inbox/Signals"],
        "requires_review": true,
        "state": "alert",
        "tags": ["signal", "critical", "{{topic}}", "{{project}}"],
        "escalation_required": true,
        "notifications": ["push", "email"],
        "additional_processing": ["create_summary", "extract_entities", "create_relationships"]
      },
      "priority": 4
    },
    {
      "rule_id": "route-005",
      "name": "Dynamic Signals Moderate Priority",
      "description": "Signals with moderate relevance, worth keeping in knowledge base",
      "pattern_type": ["rss", "api"],
      "conditions": {
        "overall_score_min": 0.50,
        "overall_score_max": 0.74,
        "classification": ["unclassified", "public"]
      },
      "action": {
        "destination": "10-Projects/External-Intelligence",
        "requires_review": false,
        "state": "provisional",
        "tags": ["signal", "{{topic}}", "{{project}}"],
        "escalation_required": false,
        "additional_processing": ["create_summary", "extract_entities"]
      },
      "priority": 5
    },
    {
      "rule_id": "route-006",
      "name": "Dynamic Signals Low Signal (Archive)",
      "description": "Signals with low relevance or low credibility",
      "pattern_type": ["rss", "api"],
      "conditions": {
        "overall_score_min": 0.30,
        "overall_score_max": 0.49
      },
      "action": {
        "destination": "00-Archive/Signals",
        "requires_review": false,
        "state": "archived",
        "tags": ["signal", "archived", "low-relevance"],
        "retention_days": 30,
        "additional_processing": ["none"]
      },
      "priority": 6
    },
    {
      "rule_id": "route-007",
      "name": "Sensitive Data Quarantine",
      "description": "Any source classified as sensitive/protected/confidential",
      "pattern_type": "any",
      "conditions": {
        "classification": ["work-protected-b", "work-confidential", "sensitive"]
      },
      "action": {
        "destination": "local-vault-only",
        "requires_review": true,
        "requires_approval": true,
        "state": "quarantine",
        "tags": ["sensitive", "requires-approval", "do-not-share"],
        "escalation_required": true,
        "access_control": "restricted",
        "additional_processing": ["none"]
      },
      "priority": 0,
      "note": "Highest priority — sensitive data bypasses normal routing"
    },
    {
      "rule_id": "route-008",
      "name": "Contradictory Knowledge (Escalate)",
      "description": "Captures that contradict high-confidence existing knowledge",
      "pattern_type": "any",
      "conditions": {
        "reconciliation_status": "contradicts-high-confidence"
      },
      "action": {
        "destination": "00-Inbox/Conflicts",
        "requires_review": true,
        "requires_approval": true,
        "state": "escalated",
        "tags": ["conflict", "requires-resolution", "{{domain}}"],
        "escalation_required": true,
        "review_priority": "high",
        "additional_processing": ["create_conflict_summary"]
      },
      "priority": 1,
      "note": "Contradictions must be resolved before integration"
    },
    {
      "rule_id": "route-009",
      "name": "Very Low Signal (Quarantine)",
      "description": "Captures with very low confidence or likely noise",
      "pattern_type": "any",
      "conditions": {
        "confidence_max": 0.30
      },
      "action": {
        "destination": "00-Quarantine",
        "requires_review": false,
        "state": "quarantine",
        "tags": ["quarantine", "low-signal"],
        "retention_days": 7,
        "additional_processing": ["none"]
      },
      "priority": 10,
      "note": "Likely spam or off-topic — minimal retention"
    }
  ],
  "route_decision_flow": {
    "description": "Decision flow for routing a capture",
    "steps": [
      {
        "step": 1,
        "action": "Check classification",
        "rule_applies": ["route-007 (if sensitive)"]
      },
      {
        "step": 2,
        "action": "Check reconciliation status",
        "rule_applies": ["route-008 (if contradicts)"]
      },
      {
        "step": 3,
        "action": "Check overall confidence",
        "rule_applies": ["route-009 (if < 0.30)"]
      },
      {
        "step": 4,
        "action": "Classify source type and evaluate against pattern-specific rules",
        "rule_applies": ["route-001 to route-006 (based on pattern and confidence)"]
      }
    ]
  },
  "destination_mapping": {
    "00-Inbox": "Raw captures awaiting triage",
    "00-Inbox/Signals": "High-priority external signals",
    "00-Inbox/Conflicts": "Contradictory knowledge requiring resolution",
    "00-Quarantine": "Low-signal or potential spam (retention: 7 days)",
    "00-Archive/Signals": "Archived external signals (retention: 30 days)",
    "10-Projects/External-Sources": "Articles and PDFs from external sources",
    "10-Projects/External-Intelligence": "Signals and monitoring data",
    "{{project}}/Sources": "Project-specific external sources"
  },
  "tag_conventions": {
    "source_type": ["source", "signal", "capture"],
    "status": ["trusted", "provisional", "inbox", "alert", "archived", "quarantine"],
    "domain": ["strategic-planning", "product-delivery", "research", "operations", "governance", "external-engagement"],
    "processing": ["review", "requires-approval", "requires-resolution", "do-not-share"],
    "utility": ["reference", "action-required", "decision-critical"]
  },
  "notes": "This single routing policy applies to all three ingestion patterns. Differences are in source_type conditions and destination, not in fundamental logic."
}
